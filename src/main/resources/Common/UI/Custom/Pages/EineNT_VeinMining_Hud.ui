$C = "../Common.ui";

Group {
    Anchor: (Bottom: 80, Left: 30, Width: 180, Height: 60);

    Background: PatchStyle(TexturePath: "../Common/ContainerBackgroundSecondary.png", Border: 4);

    LayoutMode: Left;
    Padding: (Left: 10, Right: 12, Top: 8, Bottom: 8);

    Group {
        Anchor: (Width: 44, Height: 44);
        LayoutMode: Top;
        Group { FlexWeight: 1; }
        Group {
            LayoutMode: Left;
            Group { FlexWeight: 1; }
            Group #IconFreeform { Visible: false; Background: (TexturePath: "../Icons/Icon_Freeform.png"); Anchor: (Width: 44, Height: 44); }
            Group #IconTunnel3  { Visible: false; Background: (TexturePath: "../Icons/Icon_Tunnel3.png"); Anchor: (Width: 44, Height: 44); }
            Group #IconCube     { Visible: false; Background: (TexturePath: "../Icons/Icon_Cube.png"); Anchor: (Width: 44, Height: 44); }
            Group #IconTunnel2  { Visible: false; Background: (TexturePath: "../Icons/Icon_Tunnel2.png"); Anchor: (Width: 44, Height: 44); }
            Group #IconWall3    { Visible: false; Background: (TexturePath: "../Icons/Icon_Wall3.png"); Anchor: (Width: 44, Height: 44); }
            Group #IconTunnel1  { Visible: false; Background: (TexturePath: "../Icons/Icon_Tunnel1.png"); Anchor: (Width: 44, Height: 44); }
            Group #IconWall5    { Visible: false; Background: (TexturePath: "../Icons/Icon_Wall5.png"); Anchor: (Width: 44, Height: 44); }
            Group #IconDiagonal { Visible: false; Background: (TexturePath: "../Icons/Icon_Diagonal.png"); Anchor: (Width: 44, Height: 44); }
            Group { FlexWeight: 1; }
        }
        Group { FlexWeight: 1; }
    }

    Group { Anchor: (Width: 12); }

    /* Text Container */
    Group {
        FlexWeight: 1;
        LayoutMode: Top;
        Group { FlexWeight: 1; }

        Label {
            Text: "Pattern";
            Style: LabelStyle(FontSize: 12, TextColor: #99AAB5, RenderBold: true, RenderUppercase: true);
        }

        Label #ModeLabel {
            Text: "Freeform";
            Style: LabelStyle(FontSize: 18, RenderBold: true, TextColor: #55FF55);
        }

        Group { FlexWeight: 1; }
    }
}